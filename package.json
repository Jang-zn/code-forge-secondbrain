{
  "name": "vsc-secondbrain",
  "displayName": "SecondBrain: Claude → Obsidian",
  "description": "Automatically saves Claude Code conversations to your Obsidian vault",
  "version": "0.1.0",
  "publisher": "jang",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "secondbrain.setup",
        "title": "SecondBrain: Setup (Vault + API Key)"
      },
      {
        "command": "secondbrain.setApiKey",
        "title": "SecondBrain: Set Gemini API Key"
      },
      {
        "command": "secondbrain.setVaultPath",
        "title": "SecondBrain: Set Vault Path"
      },
      {
        "command": "secondbrain.processCurrent",
        "title": "SecondBrain: Process All New Conversations"
      },
      {
        "command": "secondbrain.enable",
        "title": "SecondBrain: Enable"
      },
      {
        "command": "secondbrain.disable",
        "title": "SecondBrain: Disable"
      },
      {
        "command": "secondbrain.showLogs",
        "title": "SecondBrain: Show Logs"
      },
      {
        "command": "secondbrain.testConnection",
        "title": "SecondBrain: AI 연결 테스트"
      }
    ],
    "configuration": {
      "title": "SecondBrain",
      "properties": {
        "secondbrain.vaultPath": {
          "type": "string",
          "default": "",
          "description": "Path to your Obsidian vault root directory"
        },
        "secondbrain.targetFolder": {
          "type": "string",
          "default": "claude-conversations",
          "description": "Folder inside vault to save conversation notes"
        },
        "secondbrain.minMessages": {
          "type": "number",
          "default": 3,
          "description": "Minimum number of messages required to create a note"
        },
        "secondbrain.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable/disable automatic conversation saving"
        },
        "secondbrain.summaryModel": {
          "type": "string",
          "default": "gemini-2.5-flash-lite",
          "description": "Gemini 사용 시 모델 (summaryProvider가 gemini일 때만 적용)"
        },
        "secondbrain.summaryProvider": {
          "type": "string",
          "enum": [
            "claude-cli",
            "gemini"
          ],
          "enumDescriptions": [
            "로컬에 설치된 Claude Code CLI 사용 (추가 비용 없음, 구독 필요)",
            "Gemini API 사용 (API 키 및 과금 필요)"
          ],
          "default": "claude-cli",
          "markdownDescription": "요약에 사용할 AI 엔진. [🔗 연결 테스트](command:secondbrain.testConnection)"
        },
        "secondbrain.claudeCliModel": {
          "type": "string",
          "enum": [
            "sonnet",
            "opus",
            "haiku"
          ],
          "enumDescriptions": [
            "Claude Sonnet — 속도/품질 균형 (권장)",
            "Claude Opus — 최고 품질, 느림 (Max 구독 필요)",
            "Claude Haiku — 빠르고 저렴, 낮은 품질"
          ],
          "default": "sonnet",
          "description": "Claude CLI 사용 시 모델 선택 (summaryProvider가 claude-cli일 때 적용)"
        },
        "secondbrain.claudeCliBinary": {
          "type": "string",
          "default": "claude",
          "description": "Claude CLI 바이너리 경로 (기본: 자동 감지. nvm/Windows 환경에서도 자동으로 찾습니다. 감지 실패 시 절대 경로 직접 입력)"
        },
        "secondbrain.excludeProjects": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "제외할 프로젝트 경로 목록 (경로의 일부 또는 basename). 예: ['secret-project', '/Users/me/private']. 매칭되는 프로젝트는 자동 처리 및 전체 처리 모두에서 제외됩니다."
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "package": "vsce package",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "chokidar": "^3.6.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.3.0",
    "vitest": "^4.1.4"
  }
}
